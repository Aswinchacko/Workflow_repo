# Supabase Postgres (Project → Settings → Database → Connection string)
# DATABASE_URL = Transaction pooler URL (host has -pooler, port 6543) + ?pgbouncer=true
# DIRECT_URL   = direct/session URL (port 5432), used for migrations & seeding
DATABASE_URL="postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase Storage (Project → Settings → API)
SUPABASE_URL="https://YOUR_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Auth — generate a long random string for production
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
